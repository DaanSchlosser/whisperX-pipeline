{
    "version": "2.0.0",
    "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
            "executable": "powershell.exe",
            "args": ["-NoProfile", "-Command"]
        }
    },
    "tasks": [
        {
            // ---------------------------------------------------------------
            // Task 1 — Batch transcription of every file in Audio/
            // Language is auto-detected; you are prompted per file for speakers.
            // (Uses .vscode/batch-transcribe.ps1 — inline breaks because
            //  Windows argument parsing strips the double quotes that
            //  PowerShell -Command needs for $() expansion and `n newlines.)
            // ---------------------------------------------------------------
            "label": "1. Transcribe: All Audio Files (batch)",
            "type": "shell",
            "command": "& '.vscode/batch-transcribe.ps1'",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            // ---------------------------------------------------------------
            // Task 2 — Transcribe a single file with full control over options.
            // Language 'auto' = WhisperX auto-detects. Empty speaker fields = skip.
            // ---------------------------------------------------------------
            "label": "2. Transcribe: Single File (all options)",
            "type": "shell",
            "command": "if (-not (Test-Path '.env')) { Write-Error 'Missing .env file. Copy .env.example to .env and set HF_TOKEN first.'; exit 1 }; $envText = Get-Content '.env' -Raw; if ($envText -notmatch '(?m)^HF_TOKEN\\s*=\\s*.+$') { Write-Error 'HF_TOKEN is missing in .env. Update .env before running transcription.'; exit 1 }; $language = '${input:language}'; $minSpeakers = '${input:minSpeakers}'; $maxSpeakers = '${input:maxSpeakers}'; $audioPath = Join-Path 'Audio' '${input:audioFile}'; if (-not (Test-Path $audioPath)) { Write-Error ('Audio file not found: ' + $audioPath); exit 1 }; $args = @('transcribe.py', $audioPath, '--model', '${input:model}', '--compute-type', '${input:computeType}', '--batch-size', '${input:batchSize}', '--output-dir', '${input:outputDir}'); if ($language -and $language -ne 'auto') { $args += @('--language', $language) }; if ($minSpeakers) { $args += @('--min-speakers', $minSpeakers) }; if ($maxSpeakers) { $args += @('--max-speakers', $maxSpeakers) }; Write-Host ('Running: .venv/Scripts/python.exe ' + ($args -join ' ')); & '.venv/Scripts/python.exe' @args; exit $LASTEXITCODE",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            // ---------------------------------------------------------------
            // Task 3 — Strip [HH:MM:SS.mmm -> HH:MM:SS.mmm] timestamp prefixes
            // from a transcription file. Output: <name>_no_timestamps.txt
            // ---------------------------------------------------------------
            "label": "3. Remove Timestamps from Transcription",
            "type": "shell",
            "command": "& '.venv/Scripts/python.exe' 'remove_timestamps.py' (Join-Path 'Transcriptions' '${input:transcriptionFile}'); exit $LASTEXITCODE",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            // ---------------------------------------------------------------
            // Task 4 — Run the full local quality gate used in CI.
            // ---------------------------------------------------------------
            "label": "4. Quality: Ruff + Mypy",
            "type": "shell",
            "command": "& '.venv/Scripts/python.exe' -m ruff check .; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; & '.venv/Scripts/python.exe' -m ruff format --check .; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; & '.venv/Scripts/python.exe' -m mypy .; exit $LASTEXITCODE",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true,
                "echo": false
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "audioFile",
            "type": "promptString",
            "description": "Audio filename inside Audio/ (e.g. interview.mp3)",
            "default": ""
        },
        {
            "id": "model",
            "type": "pickString",
            "description": "Whisper model — larger is more accurate but slower",
            "options": [
                "large-v2",
                "large-v3",
                "medium",
                "small",
                "base",
                "tiny"
            ],
            "default": "large-v2"
        },
        {
            "id": "language",
            "type": "promptString",
            "description": "Language code (e.g. nl, en, fr, de) — leave as 'auto' to auto-detect",
            "default": "auto"
        },
        {
            "id": "minSpeakers",
            "type": "promptString",
            "description": "Minimum number of speakers — leave empty to let the model decide",
            "default": ""
        },
        {
            "id": "maxSpeakers",
            "type": "promptString",
            "description": "Maximum number of speakers — leave empty to let the model decide",
            "default": ""
        },
        {
            "id": "batchSize",
            "type": "promptString",
            "description": "Transcription batch size — lower (e.g. 8) if you get GPU out-of-memory errors",
            "default": "16"
        },
        {
            "id": "computeType",
            "type": "pickString",
            "description": "Compute precision — float16 is fastest on GPU; int8 is used automatically on CPU",
            "options": [
                "float16",
                "float32",
                "int8"
            ],
            "default": "float16"
        },
        {
            "id": "outputDir",
            "type": "promptString",
            "description": "Output directory for transcription results",
            "default": "Transcriptions"
        },
        {
            "id": "transcriptionFile",
            "type": "promptString",
            "description": "Transcription filename inside Transcriptions/ (e.g. interview.txt)",
            "default": ""
        }
    ]
}
